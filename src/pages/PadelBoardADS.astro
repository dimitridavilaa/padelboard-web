---
// PadelBoard ADS - Landing Page
// getpadelboard.com/PadelBoardADS
const lang = "es";
const whatsappNumber = "593987211803";
const whatsappMsg = encodeURIComponent("Hola, me interesa saber más sobre PadelBoard ADS.");
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMsg}`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO -->
  <title>PadelBoard ADS | Publicidad Digital en Canchas de Pádel</title>
  <meta name="description" content="Convierte tu cancha en una fuente de ingresos extra. PadelBoard ADS permite a clubes mostrar publicidad digital y a marcas llegar a una audiencia premium en clubes de pádel." />
  <meta name="keywords" content="publicidad pádel, ingresos clubes pádel, digital signage pádel, monetizar cancha pádel, PadelBoard ADS, publicidad digital deportiva" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://getpadelboard.com/PadelBoardADS" />

  <!-- Open Graph -->
  <meta property="og:title" content="PadelBoard ADS | Publicidad Digital en Canchas de Pádel" />
  <meta property="og:description" content="Convierte cada cancha en una fuente de ingresos extra. Para clubes y marcas." />
  <meta property="og:url" content="https://getpadelboard.com/PadelBoardADS" />
  <meta property="og:type" content="website" />

  <!-- Hreflang -->
  <link rel="alternate" hreflang="es" href="https://getpadelboard.com/PadelBoardADS" />
  <link rel="alternate" hreflang="en" href="https://getpadelboard.com/en/PadelBoardADS" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <style>
    :root {
      --blue: #1B5EF7;
      --blue-light: #4B7FFF;
      --blue-glow: rgba(27, 94, 247, 0.3);
      --gold: #F5C518;
      --navy: #060D1F;
      --navy-mid: #0C1A35;
      --navy-card: #0F2040;
      --white: #FFFFFF;
      --gray: #8A9BB5;
      --gray-light: #C5D0E0;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--navy);
      color: var(--white);
      overflow-x: hidden;
    }

    h1, h2, h3, .display {
      font-family: 'Bebas Neue', sans-serif;
      letter-spacing: 0.03em;
    }

    /* ─── NAV ─── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 4%;
      background: rgba(6, 13, 31, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(27, 94, 247, 0.15);
    }

    nav .logo img { height: 36px; }

    nav .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
      list-style: none;
    }

    nav .nav-links a {
      color: var(--gray-light);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
    }

    nav .nav-links a:hover { color: var(--white); }

    nav .lang-switch {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    nav .lang-switch a {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--gray);
      transition: color 0.2s;
    }

    nav .lang-switch a.active { color: var(--blue-light); }
    nav .lang-switch span { color: var(--gray); font-size: 0.7rem; }

    .btn-nav {
      background: var(--blue);
      color: var(--white) !important;
      padding: 0.5rem 1.2rem;
      border-radius: 4px;
      font-weight: 600 !important;
      transition: background 0.2s !important;
    }

    .btn-nav:hover { background: var(--blue-light) !important; }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 120px 4% 80px;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 70% 50%, rgba(27, 94, 247, 0.18) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 20% 80%, rgba(245, 197, 24, 0.06) 0%, transparent 60%),
        var(--navy);
      z-index: 0;
    }

    .hero-grid-lines {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(27, 94, 247, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(27, 94, 247, 0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      z-index: 0;
    }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 680px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(27, 94, 247, 0.15);
      border: 1px solid rgba(27, 94, 247, 0.4);
      border-radius: 100px;
      padding: 0.4rem 1rem;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--blue-light);
      margin-bottom: 1.5rem;
      animation: fadeUp 0.6s ease both;
    }

    .hero-badge .dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--blue-light);
      animation: pulse 2s infinite;
    }

    .hero h1 {
      font-size: clamp(3.5rem, 8vw, 7rem);
      line-height: 0.95;
      margin-bottom: 1.5rem;
      animation: fadeUp 0.6s 0.1s ease both;
    }

    .hero h1 .accent { color: var(--blue-light); }
    .hero h1 .gold { color: var(--gold); }

    .hero-sub {
      font-size: 1.1rem;
      color: var(--gray-light);
      line-height: 1.6;
      max-width: 520px;
      margin-bottom: 2.5rem;
      animation: fadeUp 0.6s 0.2s ease both;
    }

    .hero-ctas {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      animation: fadeUp 0.6s 0.3s ease both;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: var(--blue);
      color: var(--white);
      padding: 0.9rem 2rem;
      border-radius: 6px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      transition: all 0.2s;
      box-shadow: 0 0 30px rgba(27, 94, 247, 0.4);
    }

    .btn-primary:hover {
      background: var(--blue-light);
      transform: translateY(-2px);
      box-shadow: 0 0 40px rgba(27, 94, 247, 0.6);
    }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: transparent;
      color: var(--white);
      padding: 0.9rem 2rem;
      border-radius: 6px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      border: 1px solid rgba(255,255,255,0.2);
      transition: all 0.2s;
    }

    .btn-secondary:hover {
      border-color: rgba(255,255,255,0.5);
      background: rgba(255,255,255,0.05);
    }

    .hero-stats {
      display: flex;
      gap: 3rem;
      margin-top: 4rem;
      padding-top: 2.5rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      animation: fadeUp 0.6s 0.4s ease both;
    }

    .stat-item .stat-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.2rem;
      color: var(--white);
      letter-spacing: 0.02em;
    }

    .stat-item .stat-num span { color: var(--blue-light); }

    .stat-item .stat-label {
      font-size: 0.78rem;
      color: var(--gray);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-top: 0.2rem;
    }

    /* ─── AUDIENCE SPLIT ─── */
    .audience-split {
      padding: 5rem 4%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5px;
      background: rgba(27, 94, 247, 0.2);
    }

    .audience-card {
      background: var(--navy-mid);
      padding: 3rem 3.5rem;
      cursor: pointer;
      transition: background 0.3s;
      position: relative;
      overflow: hidden;
    }

    .audience-card::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: var(--blue);
      transform: scaleX(0);
      transition: transform 0.3s;
    }

    .audience-card:hover::before { transform: scaleX(1); }
    .audience-card:hover { background: var(--navy-card); }

    .audience-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .audience-card h3 {
      font-size: 1.8rem;
      margin-bottom: 0.75rem;
    }

    .audience-card p {
      color: var(--gray-light);
      line-height: 1.6;
      font-size: 0.95rem;
    }

    .audience-arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1.5rem;
      color: var(--blue-light);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      text-decoration: none;
    }

    /* ─── SECTIONS COMMON ─── */
    section { padding: 6rem 4%; }

    .section-label {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--blue-light);
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-size: clamp(2.5rem, 5vw, 4rem);
      line-height: 1;
      margin-bottom: 1.25rem;
    }

    .section-desc {
      color: var(--gray-light);
      font-size: 1.05rem;
      line-height: 1.7;
      max-width: 560px;
    }

    /* ─── FOR CLUBS ─── */
    .for-clubs {
      background: var(--navy-mid);
    }

    .for-clubs-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .clubs-features {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-top: 2.5rem;
    }

    .feature-item {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }

    .feature-icon {
      width: 44px;
      height: 44px;
      background: rgba(27, 94, 247, 0.15);
      border: 1px solid rgba(27, 94, 247, 0.3);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    .feature-text h4 {
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 0.95rem;
      margin-bottom: 0.3rem;
    }

    .feature-text p {
      color: var(--gray);
      font-size: 0.88rem;
      line-height: 1.5;
    }

    .clubs-visual {
      position: relative;
    }

    .clubs-visual-card {
      background: var(--navy-card);
      border: 1px solid rgba(27, 94, 247, 0.2);
      border-radius: 16px;
      padding: 2rem;
      text-align: center;
    }

    .pays-itself {
      background: linear-gradient(135deg, rgba(27, 94, 247, 0.2), rgba(245, 197, 24, 0.1));
      border: 1px solid rgba(245, 197, 24, 0.3);
      border-radius: 12px;
      padding: 1.5rem 2rem;
      margin-top: 1.5rem;
      text-align: center;
    }

    .pays-itself .label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gold);
      font-weight: 600;
      margin-bottom: 0.4rem;
    }

    .pays-itself p {
      font-size: 1rem;
      line-height: 1.5;
      color: var(--gray-light);
    }

    .pays-itself strong { color: var(--white); }

    /* ─── VIDEO PLACEHOLDER ─── */
    .video-placeholder {
      background: var(--navy-card);
      border: 2px dashed rgba(27, 94, 247, 0.3);
      border-radius: 12px;
      padding: 3rem 2rem;
      text-align: center;
      margin-top: 1rem;
    }

    .video-placeholder .play-icon {
      width: 60px; height: 60px;
      background: rgba(27, 94, 247, 0.2);
      border: 2px solid rgba(27, 94, 247, 0.4);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
      font-size: 1.5rem;
    }

    .video-placeholder p {
      color: var(--gray);
      font-size: 0.85rem;
    }

    /* ─── FOR BRANDS ─── */
    .for-brands { background: var(--navy); }

    .for-brands-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .brands-metrics {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 2.5rem;
    }

    .metric-card {
      background: var(--navy-card);
      border: 1px solid rgba(27, 94, 247, 0.15);
      border-radius: 10px;
      padding: 1.5rem;
    }

    .metric-card .metric-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.4rem;
      color: var(--blue-light);
      letter-spacing: 0.02em;
    }

    .metric-card .metric-label {
      font-size: 0.78rem;
      color: var(--gray);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-top: 0.2rem;
    }

    .audience-profile {
      background: var(--navy-card);
      border: 1px solid rgba(27, 94, 247, 0.2);
      border-radius: 12px;
      padding: 2rem;
    }

    .audience-profile h4 {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--blue-light);
      margin-bottom: 1.2rem;
    }

    .profile-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .tag {
      background: rgba(27, 94, 247, 0.12);
      border: 1px solid rgba(27, 94, 247, 0.25);
      border-radius: 100px;
      padding: 0.35rem 0.85rem;
      font-size: 0.82rem;
      color: var(--gray-light);
    }

    /* ─── HOW IT SHOWS ─── */
    .how-it-shows {
      background: var(--navy-mid);
    }

    .how-inner { text-align: center; }

    .how-inner .section-desc { margin: 0 auto 3.5rem; }

    .moments-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
      max-width: 700px;
      margin: 0 auto 3.5rem;
    }

    .moment-card {
      background: var(--navy-card);
      border: 1px solid rgba(27, 94, 247, 0.15);
      border-radius: 12px;
      padding: 2rem 1.5rem;
      text-align: left;
    }

    .moment-card .moment-badge {
      display: inline-block;
      background: rgba(27, 94, 247, 0.15);
      border: 1px solid rgba(27, 94, 247, 0.3);
      border-radius: 4px;
      padding: 0.25rem 0.6rem;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--blue-light);
      margin-bottom: 1rem;
    }

    .moment-card h4 {
      font-family: 'DM Sans', sans-serif;
      font-weight: 600;
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .moment-card p {
      color: var(--gray);
      font-size: 0.85rem;
      line-height: 1.5;
    }

    .exclusivity-banner {
      background: linear-gradient(135deg, rgba(27, 94, 247, 0.15), rgba(245, 197, 24, 0.08));
      border: 1px solid rgba(245, 197, 24, 0.25);
      border-radius: 12px;
      padding: 1.5rem 2.5rem;
      display: inline-flex;
      align-items: center;
      gap: 1.5rem;
      max-width: 600px;
    }

    .exclusivity-banner .exc-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3.5rem;
      color: var(--gold);
      line-height: 1;
      flex-shrink: 0;
    }

    .exclusivity-banner p {
      color: var(--gray-light);
      font-size: 0.95rem;
      line-height: 1.5;
      text-align: left;
    }

    .exclusivity-banner strong { color: var(--white); }

    /* ─── SAAS PLATFORM ─── */
    .saas-section { background: var(--navy); }

    .saas-inner {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 5rem;
      align-items: center;
    }

    .saas-features {
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
      margin-top: 2rem;
    }

    .saas-feature {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.2rem;
      background: var(--navy-card);
      border: 1px solid rgba(27, 94, 247, 0.1);
      border-radius: 8px;
      transition: border-color 0.2s;
    }

    .saas-feature:hover { border-color: rgba(27, 94, 247, 0.35); }

    .saas-feature .sf-icon {
      font-size: 1.3rem;
      width: 40px;
      flex-shrink: 0;
      text-align: center;
    }

    .saas-feature span {
      font-size: 0.92rem;
      color: var(--gray-light);
    }

    .saas-screenshot {
      background: var(--navy-card);
      border: 1px solid rgba(27, 94, 247, 0.2);
      border-radius: 16px;
      padding: 1.5rem;
      position: relative;
    }

    .saas-screenshot img {
      width: 100%;
      border-radius: 8px;
      display: block;
    }

    .saas-screenshot-placeholder {
      background: rgba(27, 94, 247, 0.06);
      border: 2px dashed rgba(27, 94, 247, 0.2);
      border-radius: 8px;
      padding: 4rem 2rem;
      text-align: center;
      color: var(--gray);
      font-size: 0.85rem;
    }

    /* ─── COMPARISON ─── */
    .comparison { background: var(--navy-mid); }

    .comparison-inner { max-width: 800px; margin: 0 auto; text-align: center; }

    .comparison-table {
      margin-top: 3rem;
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(27, 94, 247, 0.2);
    }

    .comp-header {
      padding: 1rem 1.5rem;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .comp-col-pb { background: rgba(27, 94, 247, 0.2); color: var(--blue-light); }
    .comp-col-imp { background: rgba(255,255,255,0.04); color: var(--gray); }
    .comp-row-label { background: rgba(255,255,255,0.02); padding: 1rem 1.5rem; font-size: 0.88rem; color: var(--gray-light); border-top: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; }
    .comp-cell { padding: 1rem 1.5rem; font-size: 0.88rem; border-top: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; text-align: center; }
    .comp-cell.pb { background: rgba(27, 94, 247, 0.08); }
    .comp-cell.imp { background: rgba(255,255,255,0.02); color: var(--gray); }
    .check { color: #4CAF50; font-size: 1.1rem; }
    .cross { color: #EF5350; font-size: 1.1rem; }

    .price-highlight {
      margin-top: 2rem;
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .price-card {
      background: var(--navy-card);
      border: 1px solid rgba(27, 94, 247, 0.2);
      border-radius: 12px;
      padding: 1.5rem 2.5rem;
      text-align: center;
    }

    .price-card.featured {
      border-color: var(--blue);
      background: rgba(27, 94, 247, 0.12);
    }

    .price-card .price-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gray);
      margin-bottom: 0.5rem;
    }

    .price-card .price-featured { color: var(--blue-light); }

    .price-card .price-amount {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      line-height: 1;
    }

    .price-card .price-period {
      font-size: 0.8rem;
      color: var(--gray);
      margin-top: 0.3rem;
    }

    /* ─── CTA FINAL ─── */
    .cta-final {
      background: var(--navy);
      text-align: center;
      padding: 7rem 4%;
      position: relative;
      overflow: hidden;
    }

    .cta-final::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(27, 94, 247, 0.15) 0%, transparent 70%);
      pointer-events: none;
    }

    .cta-final h2 {
      font-size: clamp(3rem, 6vw, 5.5rem);
      line-height: 1;
      margin-bottom: 1.25rem;
      position: relative;
    }

    .cta-final p {
      color: var(--gray-light);
      font-size: 1.05rem;
      max-width: 500px;
      margin: 0 auto 2.5rem;
      line-height: 1.6;
      position: relative;
    }

    .cta-buttons {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
      position: relative;
    }

    /* ─── FORM ─── */
    .contact-form {
      background: var(--navy-mid);
      padding: 5rem 4%;
    }

    .form-inner {
      max-width: 640px;
      margin: 0 auto;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 2.5rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .form-group.full { grid-column: 1 / -1; }

    .form-group label {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--gray);
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      background: var(--navy-card);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 6px;
      padding: 0.75rem 1rem;
      color: var(--white);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      transition: border-color 0.2s;
      outline: none;
    }

    .form-group select {
      appearance: none;
      cursor: pointer;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--blue);
    }

    .form-group textarea { resize: vertical; min-height: 110px; }

    .btn-submit {
      width: 100%;
      background: var(--blue);
      color: var(--white);
      border: none;
      padding: 1rem;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 1rem;
      transition: all 0.2s;
      letter-spacing: 0.03em;
    }

    .btn-submit:hover {
      background: var(--blue-light);
      transform: translateY(-1px);
    }

    /* ─── FOOTER ─── */
    footer {
      background: var(--navy-mid);
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 2rem 4%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    footer img { height: 28px; }

    footer p {
      font-size: 0.8rem;
      color: var(--gray);
    }

    footer .footer-links {
      display: flex;
      gap: 1.5rem;
    }

    footer .footer-links a {
      font-size: 0.8rem;
      color: var(--gray);
      text-decoration: none;
      transition: color 0.2s;
    }

    footer .footer-links a:hover { color: var(--white); }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }

    .fade-in {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .for-clubs-inner,
      .for-brands-inner,
      .saas-inner { grid-template-columns: 1fr; gap: 3rem; }

      .audience-split { grid-template-columns: 1fr; }

      .hero-stats { gap: 1.5rem; flex-wrap: wrap; }

      .moments-grid { grid-template-columns: 1fr; max-width: 420px; }

      .brands-metrics { grid-template-columns: 1fr 1fr; }

      .comparison-table { font-size: 0.82rem; }

      nav .nav-links { display: none; }

      .form-grid { grid-template-columns: 1fr; }

      footer { flex-direction: column; text-align: center; }
    }

    @media (max-width: 480px) {
      .hero h1 { font-size: 3rem; }
      .hero-stats { gap: 1.2rem; }
      .price-highlight { flex-direction: column; align-items: center; }
    }
  </style>
</head>

<body>

